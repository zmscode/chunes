{
	"expo": {
		"name": "Chunes",
		"slug": "chunes",
		"version": "0.0.1",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "myapp",
		"userInterfaceStyle": "dark",
		"splash": {
			"image": "./assets/images/splash.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff"
		},
		"assetBundlePatterns": ["**/*"],
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			},
			"package": "com.zmscode.chunes"
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			"expo-font",
			[
				"expo-build-properties",
				{
					"ios": {
						"newArchEnabled": true
					},
					"android": {
						"newArchEnabled": true
					}
				}
			],
			"expo-web-browser"
		],
		"experiments": {
			"typedRoutes": true
		}
	}
}
